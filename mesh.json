{
    "meshConfig": {
        "responseConfig": {
            "CORS": {
                "origin": [
                    "https://main--oope--maxsavich.aem.page",
                    "https://main--oope--maxsavich.aem.live",
                    "http://localhost:3000"
                ],
                "methods": [
                    "GET",
                    "POST",
                    "OPTIONS"
                ],
                "maxAge": 60480,
                "credentials": false
            }
        },
        "sources": [
            {
                "name": "Commerce",
                "handler": {
                    "graphql": {
                        "endpoint": "https://na1-sandbox.api.commerce.adobe.com/ECTBneBoriYAvZKpQCMec/graphql",
                        "operationHeaders": {
                            "Magento-Website-Code": "base",
                            "Magento-Store-View-Code": "default"
                        }
                    }
                }
            },
            {
                "name": "Enrichment",
                "handler": {
                    "openapi": {
                        "source": "./enrichment-openapi.json"
                    }
                },
                "transforms": [
                    {
                        "prefix": {
                            "value": "Enrichment_",
                            "includeRootOperations": true
                        }
                    }
                ]
            },
            {
                "name": "Badges",
                "handler": {
                    "openapi": {
                        "source": "./badges-openapi.json"
                    }
                },
                "transforms": [
                    {
                        "prefix": {
                            "value": "Badges_",
                            "includeRootOperations": true
                        }
                    }
                ]
            }
        ]
    }
}
